# Telegram bot token from @BotFather
BOT_TOKEN=

# Anthropic API key — used by the Claude SDK for reading interpretations.
# The SDK reads ANTHROPIC_API_KEY from the environment automatically.
ANTHROPIC_API_KEY=

# Comma-separated Telegram user IDs with admin rights (stats, refunds).
ADMIN_IDS=

# Claude model for interpretations (default: claude-opus-4-8).
CLAUDE_MODEL=claude-opus-4-8

# Timezone that defines "today" for the daily spread (default: Europe/Kyiv).
TZ=Europe/Kyiv

# SQLite database path (default: tarot.db).
DB_PATH=tarot.db

# Default UI language for new users: ru | uk | en (default: ru).
DEFAULT_LANG=ru
